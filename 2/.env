# Domains and reverse proxy upstreams.
WEB_DOMAIN=web.au-team.irpo
DOCKER_DOMAIN=docker.au-team.irpo
WEB_UPSTREAM=172.16.1.4:8080
DOCKER_UPSTREAM=172.16.2.5:8080

# Certificate validity.
CERT_DAYS=30
CA_DAYS=30
RSA_KEY_BITS=4096

# Certificate subject.
CERT_COUNTRY=RU
CERT_STATE=HMAO
CERT_CITY=NIZHNEVARTOVSK
CERT_ORGANIZATION=AU-Team
CERT_ORG_UNIT=408
CA_COMMON_NAME="AU-Team CA"

# SSH delivery from HQ-SRV.
SSH_USER=sshuser
SSH_PASSWORD=P@ssw0rd
ISP_IP=172.16.1.1
ISP_SSH_PORT=22
HQ_CLI_IP=192.168.2.10
HQ_CLI_SSH_PORT=2026

# Existing Basic Auth from module 2 tasks 9-10.
AUTH_USER=WEB
AUTH_PASSWORD=P@ssw0rd
AUTH_REALM="Restricted Access"

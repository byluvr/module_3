# WAN addresses used as GRE and IPsec endpoints.
HQ_WAN_IP=172.16.1.4
BR_WAN_IP=172.16.2.5

# EcoRouter interface names.
HQ_WAN_INTERFACE=int0
BR_WAN_INTERFACE=int0
HQ_TUNNEL_INTERFACE=tunnel.0
BR_TUNNEL_INTERFACE=tunnel.0

# SSH access used by the Expect deployment script.
HQ_SSH_HOST=172.16.1.4
BR_SSH_HOST=172.16.2.5
ROUTER_SSH_PORT=22
ROUTER_SSH_USER=net_admin
# password or key
ROUTER_SSH_AUTH=password
ROUTER_SSH_PASSWORD=P@ssw0rd
# Used only when ROUTER_SSH_AUTH=key.
ROUTER_SSH_KEY=
# Delay between CLI commands in milliseconds.
ROUTER_COMMAND_DELAY_MS=100
# Leave empty when entering privileged mode does not require a password.
ROUTER_ENABLE_PASSWORD=

# IPsec.
IPSEC_PROFILE=VPN
CRYPTO_MAP=VPN-MAP
FILTER_MAP=VPN-FILTER
IPSEC_PSK=P@ssw0rd

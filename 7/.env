# Monitoring URL and server addresses.
MON_DOMAIN=mon.au-team.irpo
HQ_SRV_IP=192.168.1.10
BR_SRV_IP=192.168.3.10

# Directly published ports.
# Port 80 is already used by Apache from module 2, so Grafana uses 3000.
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
NODE_EXPORTER_PORT=9100

# Grafana account.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=P@ssw0rd

# Container images.
PROMETHEUS_IMAGE=prom/prometheus:latest
GRAFANA_IMAGE=grafana/grafana:latest
NODE_EXPORTER_IMAGE=quay.io/prometheus/node-exporter:latest

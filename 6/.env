# Central rsyslog server.
LOG_SERVER_IP=192.168.1.10
LOG_SERVER_PORT=514
LOG_PROTOCOL=tcp

# Remote logs and rotation.
LOG_ROOT=/opt
LOG_FILE_NAME=messages.log
ROTATE_SIZE=10M
ROTATE_COUNT=4
ROTATE_WEEKDAY=0
ROTATE_HOUR=0
ROTATE_MINUTE=0

# EcoRouter SSH access from HQ-CLI.
HQ_SSH_HOST=172.16.1.4
BR_SSH_HOST=172.16.2.5
ROUTER_SSH_PORT=22
ROUTER_SSH_USER=net_admin
ROUTER_SSH_AUTH=password
ROUTER_SSH_PASSWORD=P@ssw0rd
ROUTER_SSH_KEY=
ROUTER_COMMAND_DELAY_MS=100
ROUTER_ENABLE_PASSWORD=

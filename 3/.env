# WAN addresses used as GRE and IPsec endpoints.
HQ_WAN_IP=172.16.4.4
BR_WAN_IP=172.16.5.5

# EcoRouter interface names.
HQ_WAN_INTERFACE=int0
BR_WAN_INTERFACE=int0
HQ_TUNNEL_INTERFACE=tunnel.0
BR_TUNNEL_INTERFACE=tunnel.0

# SSH access used by the Expect deployment script.
HQ_SSH_HOST=172.16.4.4
BR_SSH_HOST=172.16.5.5
ROUTER_SSH_PORT=22
ROUTER_SSH_USER=admin
ROUTER_SSH_PASSWORD=admin
# Leave empty when entering privileged mode does not require a password.
ROUTER_ENABLE_PASSWORD=

# Existing GRE network used by dynamic routing.
HQ_TUNNEL_IP=172.16.0.1
BR_TUNNEL_IP=172.16.0.2
TUNNEL_PREFIX=30
TUNNEL_MTU=1400

# IPsec.
IPSEC_PROFILE=VPN
CRYPTO_MAP=VPN-MAP
FILTER_MAP=VPN-FILTER
IPSEC_PSK=P@ssw0rd

# Existing OSPF process.
CONFIGURE_OSPF=yes
OSPF_PROCESS=1
OSPF_NETWORK=172.16.0.0
OSPF_AREA=0.0.0.0

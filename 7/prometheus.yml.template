global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: node
    static_configs:
      - targets:
          - "__HQ_SRV_IP__:__NODE_EXPORTER_PORT__"
        labels:
          device: HQ-SRV
      - targets:
          - "__BR_SRV_IP__:__NODE_EXPORTER_PORT__"
        labels:
          device: BR-SRV

# WAN and internal networks.
HQ_WAN_IP=172.16.1.4
BR_WAN_IP=172.16.2.5
HQ_INTERNAL_NETWORKS="192.168.1.0/27 192.168.2.0/28"
BR_INTERNAL_NETWORKS="192.168.3.0/28"

# EcoRouter interface and filter names.
HQ_WAN_INTERFACE=int0
BR_WAN_INTERFACE=int0
HQ_TUNNEL_INTERFACE=tunnel.0
BR_TUNNEL_INTERFACE=tunnel.0
FIREWALL_MAP=INTERNET_IN
OLD_IPSEC_FILTER=VPN-FILTER
CRYPTO_MAP=VPN-MAP

# Services allowed from the ISP side.
ALLOWED_TCP_PORTS="22 53 80 443 8080 2026"
ALLOW_ICMP=yes

# SSH access from HQ-CLI.
HQ_SSH_HOST=172.16.1.4
BR_SSH_HOST=172.16.2.5
ROUTER_SSH_PORT=22
ROUTER_SSH_USER=net_admin
ROUTER_SSH_AUTH=password
ROUTER_SSH_PASSWORD=P@ssw0rd
ROUTER_SSH_KEY=
ROUTER_COMMAND_DELAY_MS=100
ROUTER_ENABLE_PASSWORD=
